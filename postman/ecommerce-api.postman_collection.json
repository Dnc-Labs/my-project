    {
      "name": "6. Product Image",
      "description": "Test refactor ProductImage — verify primaryImageUrl extract qua MapStruct @Named.\n\n⚠️ Upload Image cần chọn file thật ở field `file` (Body → form-data) khi chạy.",
      "item": [
        {
          "name": "Upload Image #1 (auto primary, save imageId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('imageId', res.data.id);",
                  "  console.log('✓ imageId = ' + res.data.id);",
                  "  console.log('  isPrimary = ' + res.data.isPrimary);",
                  "  console.log('  url = ' + res.data.url);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{sellerToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
